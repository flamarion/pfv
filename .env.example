# =============================================================================
# PFV2 — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- Database (required) ---
DATABASE_URL=mysql+aiomysql://pfv2:pfv2_secret@mysql:3306/pfv2
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=pfv2
MYSQL_USER=pfv2
MYSQL_PASSWORD=pfv2_secret

# --- Auth (required — generate with: openssl rand -hex 32) ---
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_NAME=PFV2
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost

# --- Redis ---
# Included in both dev and prod compose stacks
REDIS_URL=redis://redis:6379/0

# --- Frontend ---
# When using nginx (default), leave empty — API calls are same-origin via /api/
# Only set this if running frontend standalone without nginx
NEXT_PUBLIC_API_URL=
