#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Load .env if present
if [[ -f .env ]]; then
  set -a; source .env; set +a
fi

usage() {
  cat <<EOF
Usage: ./pfv <command> [options]

Commands:
  start        Build and start all services (development)
  stop         Stop all services
  restart      Restart without rebuild
  rebuild      Force rebuild (no cache) and start
  reset        Destroy all data and start fresh
  prod         Build and start in production mode (standalone frontend, no reload)
  migrate      Run pending database migrations
  logs [svc]   View logs (optional: backend, frontend, nginx, mysql, redis)
  status       Show container status
  shell [svc]  Open a shell in a service (default: backend)
  seed         Populate with mock data (demo user + 3 months of transactions)

EOF
}

cmd_start() {
  echo "Starting PFV2 stack..."
  docker compose up --build -d
  echo ""
  echo "Ready (migrations run automatically on backend startup):"
  echo "  App:      http://localhost"
  echo "  API:      http://localhost/api/"
  echo "  API docs: http://localhost/docs"
}

cmd_stop() {
  echo "Stopping..."
  docker compose down
}

cmd_restart() {
  echo "Restarting..."
  docker compose restart
}

cmd_rebuild() {
  echo "Rebuilding (no cache)..."
  docker compose build --no-cache
  docker compose up -d
  echo "Ready: http://localhost"
}

cmd_prod() {
  echo "Starting PFV2 in PRODUCTION mode..."
  docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build -d
  echo ""
  echo "Ready (production mode — standalone frontend, no reload):"
  echo "  App:      http://localhost"
  echo "  API:      http://localhost/api/"
}

cmd_reset() {
  echo "Destroying all data and starting fresh..."
  docker compose down -v

  # Rotate JWT secret to invalidate all existing tokens
  if [[ -f .env ]]; then
    local new_secret
    new_secret=$(openssl rand -hex 32)
    if grep -q "^JWT_SECRET_KEY=" .env; then
      sed -i.bak "s/^JWT_SECRET_KEY=.*/JWT_SECRET_KEY=${new_secret}/" .env && rm -f .env.bak
    else
      echo "JWT_SECRET_KEY=${new_secret}" >> .env
    fi
    echo "JWT secret rotated (all previous sessions invalidated)"
  fi

  docker compose up --build -d
  echo "Ready: http://localhost"
}

cmd_migrate() {
  docker compose exec backend alembic upgrade head
}

cmd_logs() {
  local svc="${1:-}"
  if [[ -n "$svc" ]]; then
    shift
    docker compose logs "$svc" "$@"
  else
    docker compose logs "$@"
  fi
}

cmd_status() {
  docker compose ps
}

cmd_shell() {
  local svc="${1:-backend}"
  docker compose exec "$svc" /bin/sh
}

cmd_seed() {
  echo "Seeding mock data..."
  # Pass SEED_* env vars from .env or command line
  docker compose exec \
    ${SEED_USERNAME:+-e SEED_USERNAME="$SEED_USERNAME"} \
    ${SEED_PASSWORD:+-e SEED_PASSWORD="$SEED_PASSWORD"} \
    ${SEED_EMAIL:+-e SEED_EMAIL="$SEED_EMAIL"} \
    ${SEED_ORG:+-e SEED_ORG="$SEED_ORG"} \
    backend python seed.py
}

case "${1:-}" in
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  restart)  cmd_restart ;;
  rebuild)  cmd_rebuild ;;
  prod)     cmd_prod ;;
  reset)    cmd_reset ;;
  migrate)  cmd_migrate ;;
  logs)     shift; cmd_logs "$@" ;;
  status)   cmd_status ;;
  shell)    shift; cmd_shell "$@" ;;
  seed)     cmd_seed ;;
  *)        usage ;;
esac
